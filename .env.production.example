# Shared production environment template for backend + frontend + admin

# Backend
NODE_ENV=production
PORT=5000
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=lebanese_flames
ALLOWED_IPS=
CORS_ORIGIN=https://yourdomain.com,https://admin.yourdomain.com
TRUST_PROXY=1
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_me
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRES_IN=8h
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
UPLOAD_DIR=uploads
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_smtp_password
SMTP_FROM=Lebanese Flames <orders@yourdomain.com>
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+44XXXXXXXXXX
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_WHATSAPP_CONTENT_SID=
CLOVER_ACCESS_TOKEN=
CLOVER_PRIVATE_KEY=
CLOVER_MERCHANT_ID=
CLOVER_API_BASE_URL=https://api.clover.com
CLOVER_DEFAULT_CURRENCY=gbp
APP_PUBLIC_URL=https://yourdomain.com
ADMIN_PUBLIC_URL=https://admin.yourdomain.com

# Frontend/Admin (Vite)
VITE_API_BASE_URL=https://api.yourdomain.com
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
