# ──────────────────────────────────────────────
# Backend — Production Environment Variables
# Copy this file to .env and fill in real values
# ──────────────────────────────────────────────

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/lebanese-flames?retryWrites=true&w=majority

# MySQL (Hostinger managed MySQL or external)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=lebanese_flames

# Security — whitelist your Hostinger server IPs if needed, or leave empty to allow all
ALLOWED_IPS=
CORS_ORIGIN=https://yourdomain.com,https://admin.yourdomain.com
TRUST_PROXY=1

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRES_IN=8h

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# File uploads
UPLOAD_DIR=uploads

# Google OAuth + Firebase (for Google sign-in)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
FIREBASE_PROJECT_ID=your-firebase-project-id

# Stripe (use live keys in production)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (SMTP — use SendGrid, Mailgun, or your host's SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxxxxxxx
SMTP_FROM="Lebanese Flames <orders@yourdomain.com>"

# Twilio (optional — for SMS/WhatsApp notifications)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+44XXXXXXXXXX
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_WHATSAPP_CONTENT_SID=

# Clover POS (optional)
CLOVER_ACCESS_TOKEN=
CLOVER_PRIVATE_KEY=
CLOVER_MERCHANT_ID=
CLOVER_API_BASE_URL=https://api.clover.com
CLOVER_DEFAULT_CURRENCY=gbp

# Public URLs (used for email links, Stripe webhooks)
APP_PUBLIC_URL=https://yourdomain.com
ADMIN_PUBLIC_URL=https://admin.yourdomain.com

# Node environment
NODE_ENV=production
PORT=5000
